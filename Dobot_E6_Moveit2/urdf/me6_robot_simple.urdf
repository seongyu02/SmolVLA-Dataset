<?xml version="1.0" encoding="utf-8"?>
<!-- Simplified URDF for MoveIt Setup Assistant - Visual meshes only for planning -->
<robot name="me6_robot">
  <link name="base_link">
    <inertial>
      <origin xyz="-0.024 0.004 0.032" rpy="0 0 0"/>
      <mass value="0.285"/>
      <inertia ixx="0.0004" ixy="0" ixz="0" iyy="0.0007" iyz="0" izz="0.0009"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.12"/>
